<% layout("/Layout/boilerplate") %>

<style>
  .booking-hero {
    background: linear-gradient(135deg, #fff5f5 0%, #fff 100%);
    border-left: 4px solid #fe424d;
    border-radius: 0 12px 12px 0;
  }
  .booking-card {
    border-radius: 18px;
    border: none;
    box-shadow: 0 8px 32px rgba(0,0,0,0.10);
  }
  .step-badge {
    background: #fe424d;
    color: white;
    border-radius: 50%;
    width: 28px;
    height: 28px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 13px;
    font-weight: 700;
    margin-right: 8px;
  }
  .price-row {
    display: flex;
    justify-content: space-between;
    padding: 6px 0;
    font-size: 15px;
  }
  .price-row.total {
    font-weight: 700;
    font-size: 17px;
    border-top: 2px solid #fe424d;
    margin-top: 8px;
    padding-top: 12px;
    color: #fe424d;
  }
  .btn-book {
    background: #fe424d;
    color: white;
    border: none;
    border-radius: 12px;
    padding: 14px;
    font-size: 16px;
    font-weight: 700;
    width: 100%;
    letter-spacing: 0.5px;
    transition: background 0.2s, transform 0.1s;
  }
  .btn-book:hover { background: #d6323c; color: white; transform: scale(1.01); }
  .listing-thumb {
    width: 80px;
    height: 80px;
    object-fit: cover;
    border-radius: 12px;
    border: 2px solid #f0f0f0;
  }

  @media print {
    body * { visibility: hidden !important; }
    #printArea, #printArea * { visibility: visible !important; }
    #printArea { position: fixed; top: 0; left: 0; width: 100%; padding: 30px; }
    .no-print { display: none !important; }
  }

  .ticket-wrap {
    border: 2px dashed #fe424d;
    border-radius: 16px;
    padding: 28px 32px;
    background: #fff;
    max-width: 620px;
    margin: auto;
    font-family: 'Segoe UI', sans-serif;
  }
  .ticket-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 2px solid #fe424d;
    padding-bottom: 14px;
    margin-bottom: 18px;
  }
  .ticket-brand {
    font-size: 26px;
    font-weight: 800;
    color: #fe424d;
    letter-spacing: -1px;
  }
  .ticket-label {
    font-size: 11px;
    color: #888;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 2px;
  }
  .ticket-value {
    font-size: 15px;
    font-weight: 600;
    color: #222;
    margin-bottom: 12px;
  }
  .ticket-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0 24px; }
  .ticket-footer {
    border-top: 2px solid #fe424d;
    margin-top: 18px;
    padding-top: 12px;
    text-align: center;
    font-size: 12px;
    color: #888;
  }
  .status-badge {
    background: #e6faf0;
    color: #1a7a4a;
    border-radius: 20px;
    padding: 4px 14px;
    font-size: 13px;
    font-weight: 700;
  }

  .letter-wrap {
    max-width: 620px;
    margin: auto;
    padding: 36px 40px;
    border: 1px solid #ddd;
    background: #fff;
    font-family: Georgia, serif;
    line-height: 1.7;
  }
  .letter-logo {
    font-size: 22px;
    font-weight: 900;
    color: #fe424d;
    letter-spacing: -0.5px;
  }
  .letter-date { color: #888; font-size: 13px; margin-bottom: 24px; }
  .letter-body { font-size: 15px; color: #333; }
  .letter-table {
    width: 100%;
    border-collapse: collapse;
    margin: 18px 0;
    font-size: 14px;
  }
  .letter-table td { padding: 9px 12px; border: 1px solid #e0e0e0; }
  .letter-table tr:nth-child(odd) td { background: #fafafa; }
  .letter-sig { margin-top: 32px; font-size: 14px; }
</style>

<div class="container mt-4 mb-5 no-print">

  <div class="row justify-content-center mb-3">
    <div class="col-12 col-md-10 col-lg-9">
      <a href="/listing/<%= listing._id %>" class="text-decoration-none text-muted small">
        <i class="fa-solid fa-arrow-left me-1"></i> Back to listing
      </a>
    </div>
  </div>

  <div class="row justify-content-center g-4">

    <div class="col-12 col-md-5 col-lg-4">
      <div class="card booking-card p-4">
        <div class="d-flex align-items-start gap-3 mb-3">
          <img src="<%= listing.image.url %>" class="listing-thumb" alt="listing">
          <div>
            <h6 class="mb-1 fw-bold"><%= listing.title %></h6>
            <p class="text-muted small mb-1">
              <i class="fa-solid fa-location-dot"></i>
              <%= listing.location %>, <%= listing.country %>
            </p>
            <p class="small mb-0 text-muted">by <i><%= listing.owner.username %></i></p>
          </div>
        </div>
        <hr>
        <div class="booking-hero p-3 mb-3">
          <p class="mb-1 small text-muted">Price per night</p>
          <h4 class="fw-bold mb-0" style="color:#fe424d;">
            ₹<%= listing.price.toLocaleString("en-IN") %>
          </h4>
        </div>

        <!-- Price breakdown (shown after dates picked) -->
        <div id="breakdownBox" style="display:none;">
          <div class="price-row">
            <span id="nightLabel">₹<%= listing.price.toLocaleString("en-IN") %> × — nights</span>
            <span id="nightTotal">₹0</span>
          </div>
          <div class="price-row">
            <span>Service fee</span>
            <span id="serviceFee">₹0</span>
          </div>
          <div class="price-row total">
            <span>Total</span>
            <span id="grandTotal">₹0</span>
          </div>
        </div>

        <p class="text-muted small mt-3 mb-0">
          <i class="fa-solid fa-shield-halved me-1"></i>
          Secure booking. Cancel anytime before check-in.
        </p>
      </div>
    </div>

    <div class="col-12 col-md-7 col-lg-5">
      <div class="card booking-card p-4">
        <h4 class="fw-bold mb-4">
          <span class="step-badge">1</span> Select Dates
        </h4>

        <form action="/listing/<%= listing._id %>/bookings" method="POST" id="bookingForm">
          <div class="row g-3 mb-3">
            <div class="col-12 col-sm-6">
              <label class="form-label fw-semibold">Check-In</label>
              <input type="date" name="checkIn" id="checkIn" class="form-control form-control-lg"
                     required min="<%= new Date().toISOString().split('T')[0] %>">
            </div>
            <div class="col-12 col-sm-6">
              <label class="form-label fw-semibold">Check-Out</label>
              <input type="date" name="checkOut" id="checkOut" class="form-control form-control-lg"
                     required min="<%= new Date().toISOString().split('T')[0] %>">
            </div>
          </div>

          <div id="dateError" class="alert alert-danger py-2 small" style="display:none;"></div>

          <hr class="my-4">
          <h4 class="fw-bold mb-3">
            <span class="step-badge">2</span> Guest Details
          </h4>
          <div class="mb-3">
            <label class="form-label fw-semibold">Full Name</label>
            <input type="text" class="form-control" value="<%= currentUser.username %>" disabled>
          </div>
          <div class="mb-4">
            <label class="form-label fw-semibold">Email</label>
            <input type="email" class="form-control" value="<%= currentUser.email %>" disabled>
            <div class="form-text">Confirmation will be sent to this email.</div>
          </div>

          <button type="submit" class="btn-book" id="submitBtn" disabled>
            <i class="fa-solid fa-calendar-check me-2"></i>Confirm Booking
          </button>
          <p class="text-center text-muted small mt-3 mb-0">
            You won't be charged yet — review on next step.
          </p>
        </form>
      </div>
    </div>

  </div>
</div>



<div id="printArea" style="display:none;">

  <div id="printTicket">
    <div class="ticket-wrap">
      <div class="ticket-header">
        <div class="ticket-brand">WanderLust</div>
        <div class="text-end">
          <div class="ticket-label">Document Type</div>
          <div style="font-weight:700; color:#222; font-size:15px;">Booking Ticket</div>
          <span class="status-badge mt-1 d-inline-block">CONFIRMED</span>
        </div>
      </div>
      <div class="ticket-grid">
        <div>
          <div class="ticket-label">Booking ID</div>
          <div class="ticket-value" id="pt-bookingId">—</div>

          <div class="ticket-label">Listing</div>
          <div class="ticket-value" id="pt-listing"><%= listing.title %></div>

          <div class="ticket-label">Location</div>
          <div class="ticket-value" id="pt-location"><%= listing.location %>, <%= listing.country %></div>
        </div>
        <div>
          <div class="ticket-label">Guest</div>
          <div class="ticket-value" id="pt-guest"><%= currentUser.username %></div>

          <div class="ticket-label">Check-In</div>
          <div class="ticket-value" id="pt-checkin">—</div>

          <div class="ticket-label">Check-Out</div>
          <div class="ticket-value" id="pt-checkout">—</div>

          <div class="ticket-label">Nights</div>
          <div class="ticket-value" id="pt-nights">—</div>

          <div class="ticket-label">Total Paid</div>
          <div class="ticket-value" id="pt-total" style="color:#fe424d;">—</div>
        </div>
      </div>
      <div class="ticket-footer">
        🏠 WanderLust · This is an auto-generated ticket · Please carry it during your stay
      </div>
    </div>
  </div>

  <div id="printLetter" style="display:none; margin-top: 40px;">
    <div class="letter-wrap">
      <div class="d-flex justify-content-between align-items-start mb-2">
        <div class="letter-logo">WanderLust</div>
        <div class="text-end small text-muted">
          Booking Confirmation Letter<br>
          <span id="pl-date"></span>
        </div>
      </div>
      <div class="letter-date" id="pl-issueDate"></div>
      <div class="letter-body">
        <p>Dear <strong id="pl-guest"></strong>,</p>
        <p>
          We are pleased to confirm your reservation at <strong id="pl-listing"></strong>,
          located in <strong id="pl-location"></strong>. Your booking has been successfully
          processed and confirmed.
        </p>
        <table class="letter-table">
          <tr><td><b>Booking ID</b></td><td id="pl-bookingId">—</td></tr>
          <tr><td><b>Property</b></td><td id="pl-listing2">—</td></tr>
          <tr><td><b>Location</b></td><td id="pl-location2">—</td></tr>
          <tr><td><b>Guest Name</b></td><td id="pl-guest2">—</td></tr>
          <tr><td><b>Check-In Date</b></td><td id="pl-checkin">—</td></tr>
          <tr><td><b>Check-Out Date</b></td><td id="pl-checkout">—</td></tr>
          <tr><td><b>Duration</b></td><td id="pl-nights">—</td></tr>
          <tr><td><b>Total Amount</b></td><td id="pl-total" style="color:#fe424d; font-weight:700;">—</td></tr>
          <tr><td><b>Status</b></td><td><span style="color:#1a7a4a; font-weight:700;">CONFIRMED</span></td></tr>
        </table>
        <p>
          Please present this letter or your booking ticket upon arrival.
          A copy has also been sent to your registered email address.
        </p>
        <p>
          If you have any questions or need to make changes to your reservation,
          please contact us at <a href="mailto:<%= process.env.GMAIL_USER || 'support@wanderlust.com' %>">support@wanderlust.com</a>.
        </p>
        <div class="letter-sig">
          <p>Warm regards,<br>
          <strong>WanderLust Team</strong><br>
          <span style="color:#888; font-size:13px;">wanderlust.com · Your home away from home</span>
          </p>
        </div>
      </div>
    </div>
  </div>

</div>


<div id="printBtns" class="container mb-4 no-print" style="display:none!important;">
  <div class="row justify-content-center">
    <div class="col-12 col-md-10 col-lg-9">
      <div class="card booking-card p-3">
        <p class="fw-semibold mb-3">
          <i class="fa-solid fa-print me-2" style="color:#fe424d;"></i>
          Preview & Print Documents
        </p>
        <div class="d-flex gap-2 flex-wrap">
          <button onclick="printDoc('ticket')" class="btn btn-outline-dark">
            <i class="fa-solid fa-ticket me-1"></i> Print Ticket
          </button>
          <button onclick="printDoc('letter')" class="btn btn-outline-dark">
            <i class="fa-solid fa-file-lines me-1"></i> Print Confirmation Letter
          </button>
        </div>
        <p class="text-muted small mt-2 mb-0">
          Note: Booking ID will be assigned after you confirm. These are preview prints.
        </p>
      </div>
    </div>
  </div>
</div>


<script>
const pricePerNight = <%= listing.price || 0 %>;
const checkInEl  = document.getElementById("checkIn");
const checkOutEl = document.getElementById("checkOut");
const submitBtn  = document.getElementById("submitBtn");
const dateError  = document.getElementById("dateError");
const breakdownBox = document.getElementById("breakdownBox");
const printBtns  = document.getElementById("printBtns");

function formatINR(n) {
  return "₹" + n.toLocaleString("en-IN");
}
function formatDate(d) {
  return new Date(d).toDateString();
}

function calcAndUpdate() {
  const ci = checkInEl.value;
  const co = checkOutEl.value;

  dateError.style.display = "none";
  submitBtn.disabled = true;
  breakdownBox.style.display = "none";
  printBtns.style.display = "none";

  if (!ci || !co) return;

  const nights = Math.ceil((new Date(co) - new Date(ci)) / (1000*60*60*24));

  if (nights <= 0) {
    dateError.textContent = "Check-out must be after check-in.";
    dateError.style.display = "block";
    return;
  }
  if (new Date(ci) < new Date(new Date().toDateString())) {
    dateError.textContent = "Check-in cannot be in the past.";
    dateError.style.display = "block";
    return;
  }

  const subTotal   = pricePerNight * nights;
  const serviceFee = Math.round(subTotal * 0.05);
  const grand      = subTotal + serviceFee;

  document.getElementById("nightLabel").textContent =
    formatINR(pricePerNight) + " × " + nights + " night" + (nights > 1 ? "s" : "");
  document.getElementById("nightTotal").textContent  = formatINR(subTotal);
  document.getElementById("serviceFee").textContent  = formatINR(serviceFee);
  document.getElementById("grandTotal").textContent  = formatINR(grand);
  breakdownBox.style.display = "block";

  fillPrintAreas(ci, co, nights, grand);

  submitBtn.disabled = false;
  printBtns.style.display = "block";
}

function fillPrintAreas(ci, co, nights, grand) {
  const guest    = "<%= currentUser.username %>";
  const listing  = "<%= listing.title %>";
  const location = "<%= listing.location %>, <%= listing.country %>";
  const today    = new Date().toDateString();
  const fmtGrand = formatINR(grand);

  document.getElementById("pt-guest").textContent    = guest;
  document.getElementById("pt-checkin").textContent  = formatDate(ci);
  document.getElementById("pt-checkout").textContent = formatDate(co);
  document.getElementById("pt-nights").textContent   = nights + " night" + (nights > 1 ? "s" : "");
  document.getElementById("pt-total").textContent    = fmtGrand;
  document.getElementById("pt-bookingId").textContent = "Generated after confirmation";

  document.getElementById("pl-date").textContent      = today;
  document.getElementById("pl-issueDate").textContent = "Date: " + today;
  document.getElementById("pl-guest").textContent     = guest;
  document.getElementById("pl-guest2").textContent    = guest;
  document.getElementById("pl-listing").textContent   = listing;
  document.getElementById("pl-listing2").textContent  = listing;
  document.getElementById("pl-location").textContent  = location;
  document.getElementById("pl-location2").textContent = location;
  document.getElementById("pl-bookingId").textContent = "Generated after confirmation";
  document.getElementById("pl-checkin").textContent   = formatDate(ci);
  document.getElementById("pl-checkout").textContent  = formatDate(co);
  document.getElementById("pl-nights").textContent    = nights + " night" + (nights > 1 ? "s" : "");
  document.getElementById("pl-total").textContent     = fmtGrand;
}

function printDoc(type) {
  const ticket = document.getElementById("printTicket");
  const letter = document.getElementById("printLetter");
  const area   = document.getElementById("printArea");

  area.style.display = "block";

  if (type === "ticket") {
    ticket.style.display = "block";
    letter.style.display = "none";
  } else {
    ticket.style.display = "none";
    letter.style.display = "block";
  }

  window.print();

  setTimeout(() => { area.style.display = "none"; }, 500);
}

checkInEl.addEventListener("change", calcAndUpdate);
checkOutEl.addEventListener("change", calcAndUpdate);
</script>