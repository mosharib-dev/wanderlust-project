<% layout("/Layout/boilerplate") %>
<style>
    #filters {
        display: flex;
        overflow-x: auto;
        flex-wrap: nowrap;
        align-items: center;
        padding-bottom: 0.5rem;
        -webkit-overflow-scrolling: touch;
        scrollbar-width: none;
    }

    #filters::-webkit-scrollbar {
        display: none;
    }

    .filter {
        text-decoration: none;
        color: #222222;
        text-align: center;
        margin-right: 1.30rem;
        margin-top: 1rem;
        opacity: 0.7;
        flex-shrink: 0;
    }

    .filter:hover {
        opacity: 1;
        cursor: pointer;
    }

    .filter p {
        font-size: 0.8rem;
        margin-bottom: 0;
    }

    .active-filter {
        opacity: 1 !important;
        border-bottom: 2px solid #222222;
        padding-bottom: 4px;
    }

    .tax-info {
        display: none;
    }

    .tax-toggle {
        border: 1px solid black;
        border-radius: 1rem;
        height: 3.25rem;
        padding: 1rem;
        margin-left: 1rem;
        display: flex;
        align-items: center;
        flex-shrink: 0;
    }

    /* Responsive card height */
    @media (max-width: 768px) {
        .card-img-top {
            height: 12rem !important;
        }

        .tax-toggle label {
            font-size: 0.75rem;
        }
    }
</style>
    
<div id="filters">
    <a href="/listing" class="filter <%= !activeCategory ? 'active-filter' : '' %>">
        <div><i class="fa-solid fa-fire"></i></div>
        <p>Trending</p>
    </a>
    <a href="/listing?category=room" class="filter <%= activeCategory === 'room' ? 'active-filter' : '' %>">
        <div><i class="fa-solid fa-bed"></i></div>
        <p>Room</p>
    </a>
    <a href="/listing?category=iconic cities" class="filter <%= activeCategory === 'iconic cities' ? 'active-filter' : '' %>">
        <div><i class="fa-solid fa-mountain-city"></i></div>
        <p>Iconic Cities</p>
    </a>
    <a href="/listing?category=mountains" class="filter <%= activeCategory === 'mountains' ? 'active-filter' : '' %>">
        <div><i class="fa-solid fa-mountain"></i></div>
        <p>Mountains</p>
    </a>
    <a href="/listing?category=castles" class="filter <%= activeCategory === 'castles' ? 'active-filter' : '' %>">
        <div><i class="fa-solid fa-fort-awesome"></i></div>
        <p>Castles</p>
    </a>
    <a href="/listing?category=amazing pools" class="filter <%= activeCategory === 'amazing pools' ? 'active-filter' : '' %>">
        <div><i class="fa-solid fa-person-swimming"></i></div>
        <p>Amazing Pools</p>
    </a>
    <a href="/listing?category=camping" class="filter <%= activeCategory === 'camping' ? 'active-filter' : '' %>">
        <div><i class="fa-solid fa-campground"></i></div>
        <p>Camping</p>
    </a>
    <a href="/listing?category=farms" class="filter <%= activeCategory === 'farms' ? 'active-filter' : '' %>">
        <div><i class="fa-solid fa-cow"></i></div>
        <p>Farms</p>
    </a>
    <a href="/listing?category=arctic" class="filter <%= activeCategory === 'arctic' ? 'active-filter' : '' %>">
        <div><i class="fa-solid fa-snowflake"></i></div>
        <p>Arctic</p>
    </a>
    <a href="/listing?category=domes" class="filter <%= activeCategory === 'domes' ? 'active-filter' : '' %>">
        <div><i class="fa-solid fa-igloo"></i></div>
        <p>Domes</p>
    </a>
    <a href="/listing?category=boats" class="filter <%= activeCategory === 'boats' ? 'active-filter' : '' %>">
        <div><i class="fa-solid fa-ship"></i></div>
        <p>Boats</p>
    </a>
    <div class="tax-toggle ms-auto flex-shrink-0">
        <div class="form-check-reverse form-switch">
            <input class="form-check-input" type="checkbox" role="switch" id="switchCheckDefault">
            <label class="form-check-label" for="switchCheckDefault">Display total after taxes</label>
        </div>
    </div>
</div>
    <!-- Replace your current card loop with this -->
<div class="row row-cols-lg-4 row-cols-md-2 row-cols-sm-1 row-cols-1 mt-3 g-3">
    <% for(listing of allListings) { %>
        <div class="col">
            <a href="/listing/<%= listing._id %>" class="listing-link">
                <div class="card listing-card h-100">
                    <img src="<%= listing.image.url %>" class="card-img-top" alt="listing image">
                    <div class="card-img-overlay"></div>
                    <div class="card-body">
                        <p class="card-text">
                            <b><%= listing.title %></b>
                            <br>
                            <%= listing.price.toLocaleString("en-IN", { style: "currency", currency: "INR" }) %> /night
                            <i class="tax-info"> &nbsp; +18% GST</i>
                        </p>
                    </div>
                </div>
            </a>
        </div>
    <% } %>
</div>
<script>
    let taxSwitch = document.getElementById("switchCheckDefault");
    taxSwitch.addEventListener("click", () => {
        let taxInfo = document.getElementsByClassName("tax-info");
        for(info of taxInfo)
        {   if(info.style.display != "inline")
            info.style.display =  "inline";
            else
            info.style.display = "none";
        }
    });
</script>

