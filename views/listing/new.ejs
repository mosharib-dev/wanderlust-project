<% layout("/Layout/boilerplate") %>
<div class="container mt-3">
    <div class="row justify-content-center">
        <div class="col-12 col-md-8 col-lg-6">
            <h3>Create New Listing</h3>
            <form method="POST" action="/listing" novalidate class="needs-validation" enctype="multipart/form-data">
                <div class="mb-3">
                    <label for="title" class="form-label">Title</label>
                    <input type="text" name="listing[title]" id="title" required class="form-control" placeholder="Add a catchy title">
                    <div class="valid-feedback">Title looks good!</div>
                    <div class="invalid-feedback">Please enter a valid title.</div>
                </div>
                <div class="mb-3">
                    <label for="description" class="form-label">Description</label>
                    <textarea name="listing[description]" id="description" required class="form-control" rows="3" placeholder="Enter Description"></textarea>
                    <div class="invalid-feedback">Please enter a short description.</div>
                </div>
                <div class="mb-3">
                    <label for="image" class="form-label">Upload Listing Image</label>
                    <input type="file" name="listing[image]" id="image" class="form-control" required>
                    <div class="invalid-feedback">Please upload an image file.</div>
                </div>
                <div class="mb-3">
                    <label for="category" class="form-label">Category</label>
                    <select name="listing[category]" id="category" class="form-select" required>
                        <option value="" disabled selected>Select a category</option>
                        <option value="trending">🔥 Trending</option>
                        <option value="room">🛏️ Room</option>
                        <option value="iconic cities">🏙️ Iconic Cities</option>
                        <option value="mountains">⛰️ Mountains</option>
                        <option value="castles">🏰 Castles</option>
                        <option value="amazing pools">🏊 Amazing Pools</option>
                        <option value="camping">⛺ Camping</option>
                        <option value="farms">🐄 Farms</option>
                        <option value="arctic">❄️ Arctic</option>
                        <option value="domes">🛖 Domes</option>
                        <option value="boats">🚢 Boats</option>
                    </select>
                    <div class="invalid-feedback">Please select a category.</div>
                </div>
                <div class="row">
                    <div class="mb-3 col-12 col-md-4">
                        <label for="price" class="form-label">Price</label>
                        <input type="number" name="listing[price]" id="price" required class="form-control" placeholder="1200">
                        <div class="invalid-feedback">Please enter a valid price.</div>
                    </div>
                    <div class="mb-3 col-12 col-md-8">
                        <label for="country" class="form-label">Country</label>
                        <input type="text" name="listing[country]" id="country" required class="form-control" placeholder="India">
                        <div class="invalid-feedback">Please enter a valid country.</div>
                    </div>
                </div>
                <div class="mb-3">
                    <label for="location" class="form-label">Location</label>
                    <input type="text" name="listing[location]" id="location" required class="form-control" placeholder="Jaipur, Rajasthan">
                    <div class="invalid-feedback">Please enter a valid location.</div>
                </div>
                <div class="mb-3">
                    <button type="submit" class="btn btn-dark add-btn w-100">Create Listing</button>
                </div>
            </form>
        </div>
    </div>
</div>
