<% layout("/Layout/boilerplate") %>
<script>
    const mapToken = "<%= mapToken %>";
    const listing = <%- JSON.stringify(listing) %>;
</script>

<div class="container mt-3">

    <div class="row justify-content-center">
        <div class="col-12 col-md-8">
            <h3><%= listing.title %></h3>
        </div>
    </div>

    <div class="row justify-content-center mt-2">
        <div class="col-12 col-md-8">
            <div class="card show-card listing-card">
                <img src="<%= listing.image.url %>" class="card-img-top show-img" alt="Listing Image">
                <div class="card-body">
                    <p class="card-text">Owned by: <i><%= listing.owner.username %></i></p>
                    <p class="card-text"><%= listing.description %></p>
                    <p class="card-text"><b>&#8377; <%= listing.price.toLocaleString("en-IN") %> / night</b></p>
                    <p class="card-text"><i class="fa-solid fa-location-dot"></i> <%= listing.location %>, <%= listing.country %></p>
                </div>
            </div>
        </div>
    </div>

    <!-- Edit / Delete buttons -->
    <% if(currentUser && currentUser._id.equals(listing.owner._id)){ %>
    <div class="row justify-content-center mt-3">
        <div class="col-12 col-md-8 d-flex gap-2 flex-wrap">
            <a href="/listing/<%= listing._id %>/edit" class="btn btn-dark edit-btn">Edit</a>
            <form method="POST" action="/listing/<%= listing._id %>?_method=DELETE">
                <button type="submit" class="btn btn-dark">Delete</button>
            </form>
        </div>
    </div>
    <% } %>

    <!-- Review Form -->
    <div class="row justify-content-center mt-4">
        <div class="col-12 col-md-8">
            <% if(currentUser){ %>
            <h4>Leave a Review</h4>
            <hr/>
            <form action="/listing/<%= listing._id %>/reviews" method="POST" novalidate class="needs-validation">
                <div class="mb-3 mt-3">
                    <label class="form-label">Rating</label>
                    <fieldset class="starability-slot">
                        <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked aria-label="No rating." />
                        <input type="radio" id="first-rate1" name="review[rating]" value="1" />
                        <label for="first-rate1" title="Terrible">1 star</label>
                        <input type="radio" id="first-rate2" name="review[rating]" value="2" />
                        <label for="first-rate2" title="Not good">2 stars</label>
                        <input type="radio" id="first-rate3" name="review[rating]" value="3" />
                        <label for="first-rate3" title="Average">3 stars</label>
                        <input type="radio" id="first-rate4" name="review[rating]" value="4" />
                        <label for="first-rate4" title="Very good">4 stars</label>
                        <input type="radio" id="first-rate5" name="review[rating]" value="5" />
                        <label for="first-rate5" title="Amazing">5 stars</label>
                    </fieldset>
                </div>
                <div class="mb-3">
                    <label for="comment" class="form-label">Comment</label>
                    <textarea id="comment" name="review[comment]" cols="30" rows="4" class="form-control" required></textarea>
                    <div class="invalid-feedback">Please enter a comment.</div>
                </div>
                <button type="submit" class="btn btn-outline-dark">Submit</button>
            </form>
            <hr />
            <% } %>

            <!-- Reviews List -->
            <p><b>Reviews</b></p>
            <% if(listing.reviews.length === 0){ %>
                <p>No reviews yet.</p>
            <% } else { %>
                <div class="row g-3">
                <% for(let review of listing.reviews){ %>
                    <div class="col-12 col-sm-6">
                        <div class="card h-100">
                            <div class="card-body">
                                <h5 class="card-title">@<%= review.author.username %></h5>
                                <p class="starability-result card-text" data-rating="<%= review.rating %>"></p>
                                <p class="card-text"><%= review.comment %></p>
                                <% if(currentUser && currentUser._id.equals(review.author._id)){ %>
                                <form method="POST" action="/listing/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">
                                    <button class="btn btn-sm btn-dark">Delete Review</button>
                                </form>
                                <% } %>
                            </div>
                        </div>
                    </div>
                <% } %>
                </div>
            <% } %>
        </div>
    </div>

    <!-- Map -->
    <div class="row justify-content-center mt-4 mb-4">
        <div class="col-12 col-md-8">
            <h3>Where you'll be</h3>
            <div id="map"></div>
        </div>
    </div>

</div>
<script src="/JS/map.js"></script>