<% layout("/Layout/boilerplate") %>
<script>
    const mapToken = "<%= mapToken %>";
    const listing = <%- JSON.stringify(listing) %>;
</script> 

<div class="container mt-3">

    <div class="row justify-content-center">
        <div class="col-12 col-md-8">
            <h3><%= listing.title %></h3>
        </div>
    </div>

    <div class="row justify-content-center mt-2">
        <div class="col-12 col-md-8">
            <div class="card show-card listing-card">
                <img src="<%= listing.image.url %>" class="card-img-top show-img" alt="Listing Image">
                <div class="card-body">
                    <p class="card-text">Owned by: <i><%= listing.owner.username %></i></p>
                    <p class="card-text"><%= listing.description %></p>
                    <p class="card-text"><b>&#8377; <%= listing.price.toLocaleString("en-IN") %> / night</b></p>
                    <p class="card-text"><i class="fa-solid fa-location-dot"></i> <%= listing.location %>, <%= listing.country %></p>
                    <p class="card-text"> <b>Category:</b> <%= listing.category.charAt(0).toUpperCase() + listing.category.slice(1) %></p>
                </div>
            </div>
        </div>
    </div>

    <!-- Edit / Delete buttons -->
    <% if(currentUser && currentUser._id.equals(listing.owner._id)){ %>
    <div class="row justify-content-center mt-3">
        <div class="col-12 col-md-8 d-flex gap-2 flex-wrap">
            <a href="/listing/<%= listing._id %>/edit" class="btn btn-dark edit-btn">Edit</a>
            <form method="POST" action="/listing/<%= listing._id %>?_method=DELETE">
                <button type="submit" class="btn btn-dark">Delete</button>
            </form>
        </div>
    </div>
    <% } %>

    <!-- Booking Button — visible to logged-in non-owners -->
    <% if(currentUser && !currentUser._id.equals(listing.owner._id)) { %>
    <div class="row justify-content-center mt-4">
        <div class="col-12 col-md-8">
            <div class="card shadow-sm border-0" style="border-radius:16px; overflow:hidden;">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h5 class="mb-0 fw-bold">
                                ₹<%= listing.price.toLocaleString("en-IN") %>
                                <span class="text-muted fw-normal fs-6">/ night</span>
                            </h5>
                            <p class="text-muted small mb-0 mt-1">
                                <i class="fa-solid fa-location-dot"></i>
                                <%= listing.location %>, <%= listing.country %>
                            </p>
                        </div>
                        <a href="/listing/<%= listing._id %>/book"
                        class="btn btn-lg px-4"
                        style="background-color:#fe424d; color:white; border-radius:10px; font-weight:600;">
                            <i class="fa-solid fa-calendar-check me-2"></i>Book Now
                        </a>
                    </div>
            </div>
        </div>
    </div>
</div>
<% } %>

    <!-- Owner sees quick date booking -->
    <% if(currentUser && currentUser._id.equals(listing.owner._id)) { %>
    <div class="row justify-content-center mt-4">
        <div class="col-12 col-md-8">
            <div class="alert alert-info border-0 rounded-3">
                <i class="fa-solid fa-circle-info me-2"></i> You own this listing. Guests can book it.
            </div>
        </div>
    </div>
    <% } %>

    <% if(!currentUser) { %>
    <div class="row justify-content-center mt-4">
        <div class="col-12 col-md-8">
            <div class="card shadow-sm border-0 p-4 text-center" style="border-radius:16px;">
                <p class="mb-2 text-muted">Want to stay here?</p>
                <a href="/login" class="btn btn-dark px-4 rounded-pill">Login to Book</a>
            </div>
        </div>
    </div>
    <% } %>

    <!-- Price preview script -->
    <script>
        const pricePerNight = <%= listing.price || 0 %>;
        const checkIn = document.querySelector('input[name="checkIn"]');
        const checkOut = document.querySelector('input[name="checkOut"]');
        const preview = document.getElementById("price-preview");

        function updatePreview() {
            if (checkIn.value && checkOut.value) {
                const nights = Math.ceil((new Date(checkOut.value) - new Date(checkIn.value)) / (1000*60*60*24));
                if (nights > 0) {
                    preview.innerHTML = `₹${pricePerNight.toLocaleString("en-IN")} × ${nights} nights = <b>₹${(pricePerNight * nights).toLocaleString("en-IN")}</b>`;
                } else {
                    preview.innerHTML = `<span class="text-danger">Check-out must be after check-in</span>`;
                }
            }
        }

        checkIn.addEventListener("change", updatePreview);
        checkOut.addEventListener("change", updatePreview);
    </script>
    <!-- Review Form -->
    <div class="row justify-content-center mt-4">
        <div class="col-12 col-md-8">
            <% if(currentUser){ %>
            <h4>Leave a Review</h4>
            <hr/>
            <form action="/listing/<%= listing._id %>/reviews" method="POST" novalidate class="needs-validation">
                <div class="mb-3 mt-3">
                    <label class="form-label">Rating</label>
                    <fieldset class="starability-slot">
                        <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked aria-label="No rating." />
                        <input type="radio" id="first-rate1" name="review[rating]" value="1" />
                        <label for="first-rate1" title="Terrible">1 star</label>
                        <input type="radio" id="first-rate2" name="review[rating]" value="2" />
                        <label for="first-rate2" title="Not good">2 stars</label>
                        <input type="radio" id="first-rate3" name="review[rating]" value="3" />
                        <label for="first-rate3" title="Average">3 stars</label>
                        <input type="radio" id="first-rate4" name="review[rating]" value="4" />
                        <label for="first-rate4" title="Very good">4 stars</label>
                        <input type="radio" id="first-rate5" name="review[rating]" value="5" />
                        <label for="first-rate5" title="Amazing">5 stars</label>
                    </fieldset>
                </div>
                <div class="mb-3">
                    <label for="comment" class="form-label">Comment</label>
                    <textarea id="comment" name="review[comment]" cols="30" rows="4" class="form-control" required></textarea>
                    <div class="invalid-feedback">Please enter a comment.</div>
                </div>
                <button type="submit" class="btn btn-outline-dark">Submit</button>
            </form>
            <hr />
            <% } %>

            <!-- Reviews List -->
            <p><b>Reviews</b></p>
            <% if(listing.reviews.length === 0){ %>
                <p>No reviews yet.</p>
            <% } else { %>
                <div class="row g-3">
                <% for(let review of listing.reviews){ %>
                    <div class="col-12 col-sm-6">
                        <div class="card h-100">
                            <div class="card-body">
                                <h5 class="card-title">@<%= review.author.username %></h5>
                                <p class="starability-result card-text" data-rating="<%= review.rating %>"></p>
                                <p class="card-text"><%= review.comment %></p>
                                <% if(currentUser && currentUser._id.equals(review.author._id)){ %>
                                <form method="POST" action="/listing/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">
                                    <button class="btn btn-sm btn-dark">Delete Review</button>
                                </form>
                                <% } %>
                            </div>
                        </div>
                    </div>
                <% } %>
                </div>
            <% } %>
        </div>
    </div>

    <!-- Map -->
    <div class="row justify-content-center mt-4 mb-4">
        <div class="col-12 col-md-8">
            <h3>Where you'll be</h3>
            <div id="map"></div>
        </div>
    </div>

</div>
<script src="/JS/map.js"></script>
